{
    "name": "ZMK and Keymap Drawer",
    "image": "zmkfirmware/zmk-dev-arm:3.5",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "charliermarsh.ruff",
                "ms-python.python"
            ]
        }
    },
    "postCreateCommand": "python3 -m pip install --user keymap-drawer || python3 -m pip install --user --break-system-packages keymap-drawer",
    "remoteEnv": {
        "PATH": "${containerEnv:PATH}:/root/.local/bin:${containerEnv:HOME}/.local/bin"
    }
}
